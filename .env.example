# Local dev (SQLite — no extra setup)
DATABASE_URL=sqlite:///./taskmanager.db

# MySQL (local or Railway MySQL plugin)
# DATABASE_URL=mysql+pymysql://root:password@localhost:3306/taskmanager

# Railway MySQL plugin also sets MYSQLHOST, MYSQLUSER, MYSQLPASSWORD, MYSQLPORT, MYSQLDATABASE

JWT_SECRET=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080
